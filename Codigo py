import numpy as np

def determinante(matriz):
    """Calcula el determinante de una matriz"""
    return np.linalg.det(matriz)

def resolver_cramer(A, b):
    """
    Resuelve un sistema de ecuaciones nxn usando la Regla de Cramer
    
    Parámetros:
    A: matriz de coeficientes (nxn)
    b: vector de términos independientes (nx1)
    
    Retorna:
    x: vector solución (nx1)
    """
    n = len(A)
    det_A = determinante(A)
    
    # Verificar si el sistema tiene solución única
    if abs(det_A) < 1e-10:
        print("Error: El determinante de la matriz es cero. El sistema no tiene solución única.")
        return None
    
    x = np.zeros(n)
    
    # Aplicar la Regla de Cramer
    for i in range(n):
        # Crear matriz Ai (reemplazar columna i con vector b)
        Ai = A.copy()
        Ai[:, i] = b
        
        # Calcular xi = det(Ai) / det(A)
        x[i] = determinante(Ai) / det_A
    
    return x

def main():
    print("="*50)
    print("SOLVER DE SISTEMAS DE ECUACIONES - REGLA DE CRAMER")
    print("="*50)
    
    # Obtener dimensión del sistema
    n = int(input("\nIngrese el orden del sistema (n): "))
    
    # Inicializar matrices
    A = np.zeros((n, n))
    b = np.zeros(n)
    
    # Entrada de la matriz de coeficientes A
    print(f"\nIngrese los coeficientes de la matriz A ({n}x{n}):")
    for i in range(n):
        for j in range(n):
            A[i][j] = float(input(f"A[{i+1}][{j+1}] = "))
    
    # Entrada del vector de términos independientes b
    print(f"\nIngrese los términos independientes (b):")
    for i in range(n):
        b[i] = float(input(f"b[{i+1}] = "))
    
    # Mostrar sistema
    print("\n" + "="*50)
    print("SISTEMA DE ECUACIONES:")
    print("="*50)
    print("Matriz A:")
    print(A)
    print("\nVector b:")
    print(b)
    
    # Resolver sistema
    print("\n" + "="*50)
    print("RESOLVIENDO...")
    print("="*50)
    
    det_A = determinante(A)
    print(f"Determinante de A: {det_A:.6f}")
    
    solucion = resolver_cramer(A, b)
    
    if solucion is not None:
        print("\n" + "="*50)
        print("SOLUCIÓN:")
        print("="*50)
        for i in range(n):
            print(f"x[{i+1}] = {solucion[i]:.6f}")
        
        # Verificación
        print("\n" + "="*50)
        print("VERIFICACIÓN (A·x = b):")
        print("="*50)
        resultado = np.dot(A, solucion)
        print("A·x =", resultado)
        print("b   =", b)
        print("Diferencia:", np.linalg.norm(resultado - b))

if __name__ == "__main__":
    main()
